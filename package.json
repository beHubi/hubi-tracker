{
  "name": "@hubi/tracker",
  "version": "1.0.0",
  "description": "Hubi analytics & lead capture SDK for landing pages",
  "type": "module",
  "main": "./dist/hubi-tracker.cjs",
  "module": "./dist/hubi-tracker.esm.js",
  "browser": "./dist/hubi-tracker.iife.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/hubi-tracker.esm.js",
      "require": "./dist/hubi-tracker.cjs",
      "browser": "./dist/hubi-tracker.iife.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "size": "gzip -c dist/hubi-tracker.iife.js | wc -c"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^3.1.1",
    "happy-dom": "^17.4.4",
    "rollup": "^4.30.1",
    "rollup-plugin-dts": "^6.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
