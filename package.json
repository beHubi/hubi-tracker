{
  "name": "@hubi/tracker",
  "version": "1.0.0",
  "description": "Hubi analytics & lead capture SDK for landing pages",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "size": "gzip -c dist/index.global.js | wc -c"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "happy-dom": "^17.4.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
